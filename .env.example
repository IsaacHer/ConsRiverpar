# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase renombró "anon key" a "publishable key" en 2024.
# Usa la que aparezca en tu dashboard (Settings → API).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>

SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # Solo servidor, nunca exponer al cliente

# ── Cloudflare R2 (almacenamiento de media) ──────────────────
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=<nombre-del-bucket>
NEXT_PUBLIC_CDN_BASE_URL=https://<custom-domain-o-r2-public-url>

# ── Sitio ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://riverpar.com   # Sin barra final. Usado en sitemap y robots.txt
